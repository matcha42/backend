{
  "name": "user-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/user-service",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "make build",
        "cwd": "apps/user_service"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "make test",
        "cwd": "apps/user_service"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "make watch",
        "cwd": "apps/user_service"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "make clean",
        "cwd": "apps/user_service"
      }
    }
  }
}
